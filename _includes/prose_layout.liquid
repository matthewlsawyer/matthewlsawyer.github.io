<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="{{ '/style.css' | url }}" rel="stylesheet" />
    <title>
      {{ title }}{% if published %}&nbsp;{{ published }}{% endif %}
    </title>
  </head>
  <body>
    {% include "header.html" %}
    <div class="m-auto p-4 md:p-12">
      <article
        class="prose prose-stone prose-invert prose-lg lg:prose-xl [&_a]:hover:text-white"
      >
        {{ content }}
      </article>
      {% include "footer.html" %}
    </div>
  </body>
</html>
