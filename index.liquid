---
title: Matthew L. Sawyer
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="{{ '/style.css' | url }}" rel="stylesheet" />
    <title>{{ title }}</title>
  </head>
  <body>
    <div
      class="flex justify-center items-start sm:items-center min-h-screen px-6 py-6 sm:py-0"
    >
      <div
        class="w-full max-w-4xl flex flex-col sm:flex-row gap-8 sm:gap-12 sm:items-center"
      >
        <img
          src="{{ '/assets/portrait.jpg' | url }}"
          alt="Matthew L. Sawyer"
          width="448"
          height="970"
          class="portrait-desktop w-48 lg:w-56 h-auto ring-1 ring-stone-500/60 ring-offset-2 ring-offset-stone-800"
        />

        <div class="min-w-0 flex-1">
          <a
            href="{{ '/assets/portrait.jpg' | url }}"
            class="portrait-mobile mb-5 inline-block"
          >
            <img
              src="{{ '/assets/portrait-mobile.jpg' | url }}"
              alt="Matthew L. Sawyer"
              width="793"
              height="793"
              class="h-40 w-40 rounded-full object-cover object-center ring-1 ring-stone-500/60 ring-offset-2 ring-offset-stone-800"
            />
          </a>

          <h1 class="text-4xl md:text-5xl font-bold tracking-wide">
            Matthew L. Sawyer
          </h1>

          <nav class="mt-3 flex flex-col items-start gap-1.5 text-base text-stone-400">
            <a
              class="hover:text-stone-200"
              href="https://github.com/matthewlsawyer"
              >github.com/matthewlsawyer</a
            >
            <a
              class="hover:text-stone-200"
              href="https://x.com/matthewlsawyer"
              >x.com/matthewlsawyer</a
            >
            <a class="hover:text-stone-200" href="/page/about/">about</a>
          </nav>

          <div class="mt-12 text-lg text-stone-400">
            {% assign latest = collections.posts[0] %}
            {% if latest %}
            <a
              href="{{ latest.url }}"
              class="underline underline-offset-2 hover:text-stone-200"
              >{{ latest.data.title }}</a
            >
            <span class="text-stone-500"> · {{ latest.data.published }}</span>
            <span class="text-stone-500"> · </span>
            <a
              href="/blog/"
              class="inline-block underline underline-offset-2 hover:text-stone-200"
              >all writing -&gt;</a
            >
            {% else %}
            <a
              href="/blog/"
              class="underline underline-offset-2 hover:text-stone-200"
              >writing -&gt;</a
            >
            {% endif %}
          </div>

          <div class="mt-16 text-sm text-stone-500 space-y-1">
            <a
              href="https://www.11ty.dev/"
              class="hover:text-stone-300"
              >made with 11ty</a
            >
            <p>&copy; 2026 Matthew L. Sawyer</p>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
